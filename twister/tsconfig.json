{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Plot Twist Creator",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021", "ES2022.error", "WebWorker"],
    "module": "ESNext",
    // src/exemplars/*.ts import "@plotday/twister" by package name (so the
    // embedded LLM-facing examples show real import paths). Resolving that
    // self-reference needs bundler resolution + the custom condition that
    // downstream twist/connector projects already use for the reverse case.
    // tsconfig.cli.json overrides moduleResolution back to "node" for its
    // CommonJS output ("bundler" is incompatible with CommonJS, TS5095).
    "moduleResolution": "bundler",
    "customConditions": ["@plotday/connector"],
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "composite": false,
    "declaration": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
